# Copy this file to .env and fill in real values.
# Never commit real secrets.

# Application
APP_ENV=development
APP_URL=http://localhost:3000

# Auth / Verification pipeline
JWT_SECRET=__REPLACE_ME__
VERIFICATION_WEBHOOK_SECRET=__REPLACE_ME__

# Database
DATABASE_URL=__REPLACE_ME__

# Email/SMS providers
SMTP_HOST=__REPLACE_ME__
SMTP_PORT=__REPLACE_ME__
SMTP_USER=__REPLACE_ME__
SMTP_PASS=__REPLACE_ME__

# Optional: third-party APIs
API_KEY=__REPLACE_ME__
