# Copy this file to .env and fill in real values.
# Never commit real secrets.

# Application
APP_ENV=development
APP_URL=http://localhost:3000

# Django
DJANGO_SETTINGS_MODULE=aerodrive.settings
DJANGO_SECRET_KEY=__REPLACE_ME__
DJANGO_DEBUG=true

# MongoDB
MONGO_URI=mongodb://localhost:27017/

# ImageKit (for license/selfie uploads)
IMAGEKIT_PRIVATE_KEY=__REPLACE_ME__
IMAGEKIT_PUBLIC_KEY=__REPLACE_ME__
IMAGEKIT_URL_ENDPOINT=__REPLACE_ME__

# Email (OTP delivery)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=__REPLACE_ME__
EMAIL_HOST_PASSWORD=__REPLACE_ME__
DEFAULT_FROM_EMAIL=AeroDrive <noreply@aerodrive.local>

# Verification pipeline
# (Backend stores booking OTPs hashed; face match uses cnn_verify mock.)
VERIFICATION_PIPELINE_ENABLED=true
